{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MedicinesExport",
  "description": "Schema for the full exported medicines JSON file",
  "type": "object",
  "required": ["exported_at", "exported_by", "total", "medicines"],
  "additionalProperties": false,
  "properties": {
    "exported_at": {
      "type": "string",
      "description": "ISO 8601 datetime of export",
      "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
    },
    "exported_by": {
      "type": "string",
      "description": "System or user that triggered the export",
      "minLength": 1
    },
    "total": {
      "type": "integer",
      "description": "Total number of medicine records in the file",
      "minimum": 0
    },
    "medicines": {
      "type": "array",
      "description": "Array of medicine objects",
      "items": {
        "$ref": "medicine_schema.json"
      }
    }
  }
}
